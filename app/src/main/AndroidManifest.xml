<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:name=".UfiRemoteApplication"
        android:label="@string/app_name"
        android:theme="@style/Theme.UfiToolsRemote"
        android:usesCleartextTraffic="true">
        <activity
            android:name=".ComposeSmsActivity"
            android:exported="false" />
        <activity
            android:name=".SmsDetailActivity"
            android:exported="false" />
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <receiver
            android:name=".widget.UfiRemoteWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.example.ufitoolsremote.widget.ACTION_REFRESH" />
                <action android:name="com.example.ufitoolsremote.widget.ACTION_OPEN_APP" />
                <action android:name="com.example.ufitoolsremote.widget.ACTION_QUICK_REPLY" />
                <action android:name="com.example.ufitoolsremote.widget.ACTION_OPEN_SMS_DETAIL" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/ufi_remote_widget_info" />
        </receiver>
        <receiver
            android:name=".easytier.EasyTierBootReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>
        <service
            android:name=".widget.WidgetSmsListRemoteViewsService"
            android:exported="false"
            android:permission="android.permission.BIND_REMOTEVIEWS" />
        <service
            android:name=".easytier.EasyTierService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />
    </application>
</manifest>
